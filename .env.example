# Placeholder values only. Do not commit real secrets, production URLs, or credentials.

NODE_ENV=development
HOST=127.0.0.1
PORT=5000

# Auth0 values must come from the real tenant/API configuration.
AUTH0_ISSUER_URL=https://example-tenant.example-region.auth0.com/
AUTH0_AUDIENCE=https://api.example.local
AUTH0_JWKS_URI=https://example-tenant.example-region.auth0.com/.well-known/jwks.json
JWKS_CACHE_TTL_SECONDS=600
JWKS_REFRESH_COOLDOWN_SECONDS=30
TOKEN_LEEWAY_SECONDS=60

# DATABASE_URL is needed only for DB-backed checks/routes, not every validation command.
DATABASE_URL=postgres://user:password@localhost:5432/nashir_backend

# Optional migration-only override. Keep disabled during DB integration tests
# unless you intend migrations to use this URL instead of TEST_DATABASE_URL.
# MIGRATION_DATABASE_URL=postgres://user:password@localhost:5432/nashir_backend

# DB integration tests must use a separate test database.
TEST_DATABASE_URL=postgres://user:password@localhost:5432/nashir_backend_test
NASHIR_ALLOW_PRODUCTION_MIGRATIONS=false

# Local contract/runtime validation reads the adjacent authority checkout from this path.
NASHIR_AUTHORITY_REPO=../nashir
